# D365 Demo Copilot — Environment Configuration
# Copy this to .env and fill in your credentials

# ==============================================================================
# D365 Environment (required)
# ==============================================================================
D365_BASE_URL=https://your-org.crm.dynamics.com

# Optional: D365 Finance & Operations URL (for F&O demos)
# D365_FO_BASE_URL=https://your-org.operations.dynamics.com

# ==============================================================================
# LLM Provider — configure ONE of the following
# ==============================================================================

# Option 1: Azure OpenAI (recommended for enterprise)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
LLM_MODEL=gpt-4o

# Option 2: GitHub Models (free for GitHub Copilot subscribers)
# GITHUB_TOKEN=ghp_...
# GITHUB_COPILOT_MODEL=openai/gpt-4o

# Option 3: OpenAI direct
# OPENAI_API_KEY=sk-...

# Option 4: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ==============================================================================
# Dataverse API (optional — enables live schema discovery + data creation)
# ==============================================================================
# DATAVERSE_TENANT_ID=
# DATAVERSE_CLIENT_ID=
# DATAVERSE_CLIENT_SECRET=

# ==============================================================================
# Microsoft Learn MCP (optional — enriches demo plans with official docs)
# ==============================================================================
# MS_LEARN_MCP_URL=https://learn.microsoft.com/api/mcp

# ==============================================================================
# Browser Settings
# ==============================================================================
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=50
AUTH_STATE_PATH=auth_state.json

# ==============================================================================
# Voice Narration (TTS)
# ==============================================================================
# Default: Edge TTS (free, no API key needed, Microsoft neural voices)
# Optional upgrade: OpenAI TTS (requires VOICE_API_KEY or OPENAI_API_KEY)
#
# VOICE_ENABLED=false          # Enable voice narration (can also toggle in sidecar)
# VOICE_PROVIDER=auto          # auto (OpenAI if key set, else Edge), edge, openai
# VOICE_NAME=nova              # Voice: alloy, echo, fable, onyx, nova, shimmer
# VOICE_SPEED=1.0              # Playback speed (0.25 to 4.0)
# VOICE_MODEL=tts-1            # OpenAI only: tts-1 or tts-1-hd
# VOICE_API_KEY=               # OpenAI only: dedicated TTS API key
